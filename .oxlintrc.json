{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "node": true,
    "es2024": true
  },
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "ignorePatterns": [
    "node_modules",
    ".agents",
    ".claude",
    ".codex",
    ".cursor",
    "skills",
    ".omc",
    ".gjc",
    ".omx",
    ".hypercore",
    ".codegraph",
    "references",
    "**/*.jsonl"
  ],
  "rules": {}
}
