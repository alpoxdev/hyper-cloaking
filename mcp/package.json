{
  "name": "@alpoxdev/hyper-cloaking",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alpoxdev/hyper-cloaking.git",
    "directory": "mcp"
  },
  "description": "Legacy compatibility package for the Hyper Cloaking MCP server and engine.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "hyper-cloaking-mcp": "./dist/server.mjs",
    "hyper-cloaking-engine": "./engine/cli.mjs",
